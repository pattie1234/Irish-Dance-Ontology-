        <rdfs:domain rdf:resource="http://example.org/irishdance#Teacher"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#Dancer"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#dancesIn -->

