    <!-- http://www.w3.org/2002/07/owl#topObjectProperty -->

    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#topObjectProperty">
        <rdfs:domain rdf:resource="http://example.org/irishdance#School"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#RegistrationStatus"/>
    </rdf:Description>
    


