    <!-- http://example.org/irishdance#hasTeacher -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#hasTeacher">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#School"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#Teacher"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#isAdjudicatedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#isAdjudicatedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#Competition"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#Adjudicator"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#isOwnedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#isOwnedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://example.org/irishdance#ownsSchool"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#School"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#Teacher"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#isPerformedTo -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#isPerformedTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#DanceType"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#Music"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#isTaughtBy -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#isTaughtBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#Dancer"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#Teacher"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#ownsSchool -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#ownsSchool">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#Teacher"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#School"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#performedBy -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#performedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#Music"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#Musician"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#performsDanceType -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#performsDanceType">
