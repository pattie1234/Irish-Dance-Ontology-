    <!-- http://example.org/irishdance#Accessories -->

    <owl:Class rdf:about="http://example.org/irishdance#Accessories"/>
    


    <!-- http://example.org/irishdance#AccessoriesCosts -->

    <owl:Class rdf:about="http://example.org/irishdance#AccessoriesCosts">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Costs"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#AccomodationCosts -->

    <owl:Class rdf:about="http://example.org/irishdance#AccomodationCosts">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Costs"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Accuracy -->

    <owl:Class rdf:about="http://example.org/irishdance#Accuracy">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#TechnicalCriteria"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Adjudicator -->

    <owl:Class rdf:about="http://example.org/irishdance#Adjudicator">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Person"/>
        <owl:disjointWith rdf:resource="http://example.org/irishdance#Dancer"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#AdjudicatorRole -->

    <owl:Class rdf:about="http://example.org/irishdance#AdjudicatorRole">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Role"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#ArtisticCriteria -->

    <owl:Class rdf:about="http://example.org/irishdance#ArtisticCriteria">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#JudgingCriteria"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#BeginnerGrade -->

    <owl:Class rdf:about="http://example.org/irishdance#BeginnerGrade">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#GradeLevel"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Carriage -->

    <owl:Class rdf:about="http://example.org/irishdance#Carriage">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#TechnicalCriteria"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Ceili -->

    <owl:Class rdf:about="http://example.org/irishdance#Ceili">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#DanceStyle"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#CeiliMusic -->

    <owl:Class rdf:about="http://example.org/irishdance#CeiliMusic">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Music"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#ChamptionshipGrade -->

    <owl:Class rdf:about="http://example.org/irishdance#ChamptionshipGrade">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#GradeLevel"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Choreography -->

    <owl:Class rdf:about="http://example.org/irishdance#Choreography">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#ArtisticCriteria"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#ChoreographyTraining -->

    <owl:Class rdf:about="http://example.org/irishdance#ChoreographyTraining">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#TrainingEvent"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Competition -->

    <owl:Class rdf:about="http://example.org/irishdance#Competition">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Event"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/irishdance#hasParticipant"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">10</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/irishdance#Dancer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Confidence -->

    <owl:Class rdf:about="http://example.org/irishdance#Confidence">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#PerformanceQualityCriteria"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Costs -->

    <owl:Class rdf:about="http://example.org/irishdance#Costs"/>
    


    <!-- http://example.org/irishdance#Costume -->

    <owl:Class rdf:about="http://example.org/irishdance#Costume"/>
    


    <!-- http://example.org/irishdance#CostumeCosts -->

    <owl:Class rdf:about="http://example.org/irishdance#CostumeCosts">
