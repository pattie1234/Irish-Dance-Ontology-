    <!-- http://example.org/irishdance#hasAge -->

    <owl:DatatypeProperty rdf:about="http://example.org/irishdance#hasAge">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#Dancer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/irishdance#hasCompetitionName -->

    <owl:DatatypeProperty rdf:about="http://example.org/irishdance#hasCompetitionName">
