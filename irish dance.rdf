<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/irishdance/"
     xml:base="http://example.org/irishdance/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:irishdance="http://example.org/irishdance#">
    <owl:Ontology rdf:about="http://example.org/irishdance"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/irishdance#adjudicates -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#adjudicates">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#Adjudicator"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#Competition"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#belongsToSchool -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#belongsToSchool">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://example.org/irishdance#ownsSchool"/>
        <rdfs:domain rdf:resource="http://example.org/irishdance#Dancer"/>
        <rdfs:range rdf:resource="http://example.org/irishdance#School"/>
    </owl:ObjectProperty>
    


    <!-- http://example.org/irishdance#coaches -->

    <owl:ObjectProperty rdf:about="http://example.org/irishdance#coaches">
