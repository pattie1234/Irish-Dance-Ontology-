    <!-- http://example.org/irishdance#CulturalMusic -->

    <owl:Class rdf:about="http://example.org/irishdance#CulturalMusic">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Music"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#DanceMovesTraining -->

    <owl:Class rdf:about="http://example.org/irishdance#DanceMovesTraining">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#TrainingEvent"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#DanceRole -->

    <owl:Class rdf:about="http://example.org/irishdance#DanceRole">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Role"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#DanceStyle -->

    <owl:Class rdf:about="http://example.org/irishdance#DanceStyle"/>
    


    <!-- http://example.org/irishdance#DanceType -->

    <owl:Class rdf:about="http://example.org/irishdance#DanceType">
        <owl:disjointWith rdf:resource="http://example.org/irishdance#Unregistered"/>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Dancer -->

    <owl:Class rdf:about="http://example.org/irishdance#Dancer">
        <rdfs:subClassOf rdf:resource="http://example.org/irishdance#Person"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/irishdance#belongsToSchool"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/irishdance#School"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://example.org/irishdance#Event -->

    <owl:Class rdf:about="http://example.org/irishdance#Event"/>
    


    <!-- http://example.org/irishdance#EventEntryCosts -->

    <owl:Class rdf:about="http://example.org/irishdance#EventEntryCosts">
